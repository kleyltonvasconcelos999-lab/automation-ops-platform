# DATABASE
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password123
DB_NAME=automation_ops
DATABASE_URL=postgresql://admin:password123@localhost:5432/automation_ops

# REDIS
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# SERVER
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2024
JWT_EXPIRES_IN=7d

# PLAYWRIGHT
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_RETRIES=3
PLAYWRIGHT_SLOW_MO=0

# WEBSOCKET
WS_CORS_ORIGIN=http://localhost:3001
WS_PING_INTERVAL=25000

# LOGS
LOG_LEVEL=debug
LOG_DIR=./logs

# FILES
SCREENSHOTS_DIR=./screenshots
UPLOADS_DIR=./uploads
SCREENSHOT_COMPRESSION=80
MAX_SCREENSHOT_SIZE=5242880

# CORS
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# EMAIL (OPCIONAL)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@automationops.com

# WHATSAPP (OPCIONAL)
WHATSAPP_API_KEY=your-api-key
WHATSAPP_API_URL=https://api.whatsapp.com

# S3/STORAGE (OPCIONAL)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=
