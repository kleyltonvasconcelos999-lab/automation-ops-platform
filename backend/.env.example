# DATABASE
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password123
DB_NAME=automation_ops
DATABASE_URL=postgresql://admin:password123@localhost:5432/automation_ops

# REDIS
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# SERVER
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2024
JWT_EXPIRES_IN=7d

# PLAYWRIGHT
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_RETRIES=3
PLAYWRIGHT_SLOWMO=0

# WEBSOCKET
WS_PORT=3000
WS_CORS_ORIGIN=http://localhost:3001

# LOGS
LOG_LEVEL=debug
LOG_DIR=./logs

# SCREENSHOTS
SCREENSHOTS_DIR=./screenshots
SCREENSHOT_COMPRESSION=80
SCREENSHOT_QUALITY=85

# CORS
CORS_ORIGIN=http://localhost:3001

# API
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=900000

# JOBS
JOB_MAX_ATTEMPTS=3
JOB_TIMEOUT=300000
