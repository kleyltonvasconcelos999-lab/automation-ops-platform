{
  "name": "automation-ops-platform",
  "version": "1.0.0",
  "description": "Central Operacional de Automação em Tempo Real",
  "main": "backend/src/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "concurrently \"npm run build:backend\" \"npm run build:frontend\"",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start": "cd backend && node src/server.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "keywords": [
    "automation",
    "rpa",
    "monitoring",
    "realtime",
    "dashboard"
  ],
  "author": "kleyltonvasconcelos999-lab",
  "license": "MIT"
}
